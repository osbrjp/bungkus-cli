{
  "base": "vite",
  "packages": ["vite", "typescript", "husky"],
  "npm": {
    "scripts": {
      "dev": "vite",
      "build": "tsc && vite build",
      "preview": "vite preview",
      "prepare": "husky"
    }
  },
  "config": {
    "path": "vite.config.ts",
    "template": "vite/vite.config.ts"
  },
  "files": [
    { "src": "vite/index.html", "dest": "index.html" },
    { "src": "vite/tsconfig.json", "dest": "tsconfig.json" },
    { "src": "vite/src/main.ts", "dest": "src/main.ts" },
    { "src": "husky/pre-commit", "dest": ".husky/pre-commit", "executable": true }
  ]
}
