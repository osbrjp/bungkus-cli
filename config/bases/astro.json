{
  "base": "astro",
  "packages": ["astro", "husky"],
  "npm": {
    "scripts": {
      "dev": "astro dev",
      "build": "astro build",
      "preview": "astro preview",
      "prepare": "husky"
    },
    "overrides": {
      "vite": "^7"
    }
  },
  "config": {
    "path": "astro.config.mjs",
    "template": "astro/astro.config.mjs"
  },
  "files": [
    { "src": "astro/src/layouts/Layout.astro", "dest": "src/layouts/Layout.astro" },
    { "src": "astro/src/pages/index.astro", "dest": "src/pages/index.astro" },
    { "src": "husky/pre-commit", "dest": ".husky/pre-commit", "executable": true }
  ]
}
