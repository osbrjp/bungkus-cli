name: Deploy to Cloudflare Workers
on:
  push:
    branches: [main]

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
{{- if eq .PM "pnpm" }}
      - uses: pnpm/action-setup@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: pnpm
      - run: pnpm install
      - run: pnpm run build
      - run: pnpm dlx wrangler deploy
        env:
          CLOUDFLARE_API_TOKEN: {{ "${{ secrets.CLOUDFLARE_API_TOKEN }}" }}
          CLOUDFLARE_ACCOUNT_ID: {{ "${{ secrets.CLOUDFLARE_ACCOUNT_ID }}" }}
{{- else if eq .PM "bun" }}
      - uses: oven-sh/setup-bun@v2
      - run: bun install
      - run: bun run build
      - run: bunx wrangler deploy
        env:
          CLOUDFLARE_API_TOKEN: {{ "${{ secrets.CLOUDFLARE_API_TOKEN }}" }}
          CLOUDFLARE_ACCOUNT_ID: {{ "${{ secrets.CLOUDFLARE_ACCOUNT_ID }}" }}
{{- else if eq .PM "yarn" }}
      - uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: yarn
      - run: yarn install
      - run: yarn build
      - run: yarn dlx wrangler deploy
        env:
          CLOUDFLARE_API_TOKEN: {{ "${{ secrets.CLOUDFLARE_API_TOKEN }}" }}
          CLOUDFLARE_ACCOUNT_ID: {{ "${{ secrets.CLOUDFLARE_ACCOUNT_ID }}" }}
{{- else }}
      - uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: npm
      - run: npm install
      - run: npm run build
      - run: npx wrangler deploy
        env:
          CLOUDFLARE_API_TOKEN: {{ "${{ secrets.CLOUDFLARE_API_TOKEN }}" }}
          CLOUDFLARE_ACCOUNT_ID: {{ "${{ secrets.CLOUDFLARE_ACCOUNT_ID }}" }}
{{- end }}
