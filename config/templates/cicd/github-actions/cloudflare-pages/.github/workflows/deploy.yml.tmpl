name: Deploy to Cloudflare Pages
on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
{{- if eq .PM "pnpm" }}
      - uses: pnpm/action-setup@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '22'
          cache: 'pnpm'
{{- else if eq .PM "bun" }}
      - uses: oven-sh/setup-bun@v2
{{- else }}
      - uses: actions/setup-node@v4
        with:
          node-version: '22'
{{- end }}
      - name: Install dependencies
        run: {{.PM}} install
      - name: Build
        run: {{.PM}} run build
      - name: Create Pages project (if not exists)
        run: pnpm exec wrangler pages project create {{ "${{ github.event.repository.name }}" }} --production-branch main || true
        env:
          CLOUDFLARE_API_TOKEN: {{ "${{ secrets.CLOUDFLARE_API_TOKEN }}" }}
          CLOUDFLARE_ACCOUNT_ID: {{ "${{ secrets.CLOUDFLARE_ACCOUNT_ID }}" }}
      - name: Deploy
        id: deploy
        uses: cloudflare/wrangler-action@v3
        with:
          apiToken: {{ "${{ secrets.CLOUDFLARE_API_TOKEN }}" }}
          accountId: {{ "${{ secrets.CLOUDFLARE_ACCOUNT_ID }}" }}
          command: pages deploy dist
          gitHubToken: {{ "${{ secrets.GITHUB_TOKEN }}" }}
      - name: Comment deployment URL on PR
        if: github.event_name == 'pull_request'
        uses: actions/github-script@v7
        env:
          DEPLOYMENT_URL: {{ "${{ steps.deploy.outputs.deployment-url }}" }}
        with:
          script: |
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: `🚀 Deployed to Cloudflare Pages\n\n**Preview:** ${process.env.DEPLOYMENT_URL}`
            })
