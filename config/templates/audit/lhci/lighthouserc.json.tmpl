{
  "ci": {
    "collect": {
      "startServerCommand": "{{ .PM }} run preview --port 3000",
      "url": ["http://localhost:3000"],
      "numberOfRuns": 3
    },
    "upload": {
      "target": "temporary-public-storage"
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.5 }]
      }
    }
  }
}
