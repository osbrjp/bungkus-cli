{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true{{if eq (printf "%s" .Database) "d1"}},
    "types": ["node", "@cloudflare/workers-types"]{{end}}
  },
  "include": ["server", "db"]
}
