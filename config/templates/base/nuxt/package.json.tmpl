{
  "name": "{{ .ProjectName }}",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "private": true,
  "scripts": {
    "dev": "nuxt dev --port 3000",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky"
    {{- if eq .Fmt "prettier"}},
    "format": "prettier check --write"
    {{- end}}
    {{- if eq .Fmt "biome"}},
    "format": "biome check --write"
    {{- end}}
    {{- if eq .Fmt "oxfmt"}},
    "format": "oxfmt",
    "lint": "oxlint"
    {{- end}}
  },
  "dependencies": {
    "nuxt": "^4.4.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
    {{- if eq .CSS "tailwindcss"}},
    "tailwindcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
    {{- end}}
  },
  "devDependencies": {
    "husky": "^9.1.7"
    {{- if eq .Fmt "prettier"}},
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1"
      {{- if eq .CSS "tailwindcss"}},
        "prettier-plugin-tailwindcss": "0.7.2"
      {{- end}}
    {{- end}}
    {{- if eq .Fmt "biome"}},
    "@biomejs/biome": "2.4.10"
    {{- end}}
    {{- if eq .Fmt "oxfmt"}},
    "oxlint": "^1.59.0"
    {{- end}}
  }
  {{- if eq .PM "pnpm"}},
  "pnpm": {
    "overrides": {
      "semver@6.3.1": "^7.7.1"
    }
  }
  {{- end}}
}
