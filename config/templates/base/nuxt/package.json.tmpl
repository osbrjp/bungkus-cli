{
  "name": "{{ .ProjectName }}",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "private": true,
  "scripts": {
    "dev": "nuxt dev --port 3000",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky"
    {{- if eq .Fmt "prettier"}},
    "format": "prettier --write ."
    {{- end}}
    {{- if eq .Fmt "biome"}},
    "format": "biome format --write ."
    {{- end}}
    {{- if eq .Fmt "oxfmt"}},
    "format": "oxfmt ."
    {{- end}}
    {{- if eq .Linter "biome"}},
    "lint": "biome lint ."
    {{- end}}
    {{- if eq .Linter "eslint"}},
    "lint": "eslint ."
    {{- end}}
    {{- if eq .Linter "oxlint"}},
    "lint": "oxlint ."
    {{- end}}
  },
  "dependencies": {
    "nuxt": "^4.4.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
    {{- if eq .CSS "tailwindcss"}},
    "tailwindcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
    {{- end}}
  },
  "devDependencies": {
    "husky": "^9.1.7"
    {{- if eq .Fmt "prettier"}},
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1"
      {{- if eq .CSS "tailwindcss"}},
        "prettier-plugin-tailwindcss": "0.7.2"
      {{- end}}
    {{- end}}
    {{- if or (eq .Fmt "biome") (eq .Linter "biome")}},
    "@biomejs/biome": "2.4.10"
    {{- end}}
    {{- if eq .Linter "eslint"}},
    "eslint": "^10.2.0",
    "@eslint/js": "^10.2.0"
    {{- end}}
    {{- if or (eq .Fmt "oxfmt") (eq .Linter "oxlint")}},
    "oxlint": "^1.59.0"
    {{- end}}
  }
  {{- if eq .PM "pnpm"}},
  "pnpm": {
    "overrides": {
      "semver@6.3.1": "^7.7.1"
    }
  }
  {{- end}}
}
