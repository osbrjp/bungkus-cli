{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
    {{- if eq .Base "astro-react" -}}
    , "jsx": "react-jsx",
    "jsxImportSource": "react"
    {{- end -}}
  }
}
