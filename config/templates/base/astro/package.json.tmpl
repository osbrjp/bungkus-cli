{
  "name": "{{.ProjectName}}",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --port 3000",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "husky"
    {{- if eq .Fmt "prettier"}},
    "format": "prettier --write ."
    {{- end}}
    {{- if eq .Fmt "biome"}},
    "format": "biome format --write ."
    {{- end}}
    {{- if eq .Linter "biome"}},
    "lint": "biome lint ."
    {{- end}}
    {{- if eq .Linter "eslint"}},
    "lint": "eslint ."
    {{- end}}
  },
  "dependencies": {
    "astro": "^6.1.3"
    {{- if eq .CSS "tailwindcss"}},
    "tailwindcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
    {{- end}}
    {{- if eq .Base "astro-react"}},
    "@astrojs/react": "^5.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
    {{- end}}
    {{- if eq .Base "astro-vue"}},
    "@astrojs/vue": "^6.0.1",
    "vue": "^3.5.32"
    {{- end}}
    {{- if eq .CMS "microcms"}},
    "microcms-js-sdk": "^3.2.0"
    {{- end}}
  },
  "devDependencies": {
    "husky": "^9.1.7"
    {{- if eq .PM "pnpm"}},
    "vite": "^6.3.5"
    {{- end}}
    {{- if eq .Fmt "prettier"}},
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1"
      {{- if eq .CSS "tailwindcss"}},
        "prettier-plugin-tailwindcss": "0.7.2"
      {{- end}}
    {{- end}}
    {{- if or (eq .Fmt "biome") (eq .Linter "biome")}},
    "@biomejs/biome": "2.4.10"
    {{- end}}
    {{- if eq .Linter "eslint"}},
    "eslint": "^10.2.0",
    "@eslint/js": "^10.2.0"
    {{- end}}
  }
  {{- if and (eq .PM "pnpm") (or (eq .Base "astro-react") (eq .Base "astro-vue"))}},
  "pnpm": {
    "overrides": {
      "semver@6.3.1": "^7.7.1"
    }
  }
  {{- end}}
}
