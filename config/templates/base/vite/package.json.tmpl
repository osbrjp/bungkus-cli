{
  "name": "{{.ProjectName}}",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite --port 3000",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepare": "husky"
    {{- if eq .Fmt "prettier"}},
    "format": "prettier check --write"
    {{- end}}
    {{- if eq .Fmt "biome"}},
    "format": "biome check --write"
    {{- end}}
  },
  "dependencies": {
    {{- if eq .CSS "tailwindcss"}}
    "tailwindcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
    {{- end}}
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "husky": "^9.1.7"
    {{- if eq .Fmt "prettier"}},
    "prettier": "3.8.1"
    {{- end}}
    {{- if eq .Fmt "biome"}},
    "@biomejs/biome": "2.4.10"
    {{- end}}
  }
}
