{{- if eq (printf "%s" .Database) "postgres" -}}
DATABASE_URL="postgres://user:password@localhost:5432/{{ .ProjectName }}"
{{- else if eq (printf "%s" .Database) "mysql" -}}
DATABASE_URL="mysql://user:password@localhost:3306/{{ .ProjectName }}"
{{- else if eq (printf "%s" .Database) "d1" -}}
# Credentials for drizzle-kit's d1-http driver (Cloudflare dashboard → D1 → API).
# At runtime the Worker uses its `DB` binding instead; see wrangler.toml.
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_DATABASE_ID=""
CLOUDFLARE_D1_TOKEN=""
{{- else -}}
DATABASE_URL="file:./sqlite.db"
{{- end }}
