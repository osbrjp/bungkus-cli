{
  "extra": "tailwindcss",
  "base": {
    "astro": {
      "packages": ["tailwindcss", "@tailwindcss/vite"],
      "imports": ["import tailwindcss from '@tailwindcss/vite';"],
      "plugins": ["tailwindcss()"],
      "files": [
        { "src": "tailwindcss/global.css", "dest": "src/styles/global.css" }
      ]
    },
    "vite": {
      "packages": ["tailwindcss", "@tailwindcss/vite"],
      "imports": ["import tailwindcss from '@tailwindcss/vite';"],
      "plugins": ["tailwindcss()"],
      "files": [
        { "src": "tailwindcss/global.css", "dest": "src/styles/global.css" }
      ]
    }
  }
}
