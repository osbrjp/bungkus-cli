{
  "extra": "prettier",
  "template": "prettier/.prettierrc",
  "base": {
    "astro": {
      "packages": ["prettier", "prettier-plugin-astro"],
      "scripts": {
        "format": "prettier --write ."
      },
      "jsonMerge": {
        "plugins": ["prettier-plugin-astro"]
      }
    },
    "vite": {
      "packages": ["prettier"],
      "scripts": {
        "format": "prettier --write ."
      }
    }
  }
}
